
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>How much could you save by shifting energy usage?</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #fff;
    color: #1a1a1a;
    font-size: 14px;
    line-height: 1.5;
  }
  .widget {
    max-width: 560px;
    margin: 0 auto;
    padding: 1.25rem 1rem 1rem;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    background: #fff;
  }
  h1 {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 0.2rem;
    color: #0C2340;
    line-height: 1.3;
  }
  .subtitle {
    font-size: 12px;
    color: #888;
    margin: 0 0 1rem;
  }

  /* Slider card — navy background */
  .slider-card {
    background: #0C2340;
    border-radius: 10px;
    padding: 1rem 1.1rem 0.75rem;
    margin-bottom: 0.75rem;
  }
  .card-title {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.85rem;
  }
  .slider-section { margin-bottom: 0.15rem; }
  .slider-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3px;
  }
  .slider-name { font-size: 12px; font-weight: 600; }
  .free-label  { color: #0095A9; }
  .peak-label  { color: #FFC844; }
  .offpeak-label { color: rgba(255,255,255,0.65); }
  .slider-meta { display: flex; gap: 12px; font-size: 11px; color: rgba(255,255,255,0.5); }
  .slider-meta span { min-width: 48px; text-align: right; }
  .slider-meta .cost { color: rgba(255,255,255,0.9); font-weight: 600; }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    border-radius: 2px;
    background: rgba(255,255,255,0.18);
    outline: none;
    cursor: pointer;
    margin-bottom: 10px;
  }
  input[type=range]:disabled { opacity: 0.35; cursor: not-allowed; }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #fff;
    cursor: pointer;
    border: none;
  }
  input[type=range]#sl-free::-webkit-slider-thumb  { background: #0095A9; }
  input[type=range]#sl-peak::-webkit-slider-thumb  { background: #FFC844; }
  input[type=range]#sl-offpeak::-webkit-slider-thumb { background: rgba(255,255,255,0.5); }
  input[type=range]::-moz-range-thumb {
    width: 16px; height: 16px;
    border-radius: 50%;
    background: #fff;
    border: none;
    cursor: pointer;
  }
  .hint { font-size: 10px; color: rgba(255,255,255,0.35); margin: 0; }
  .warn {
    font-size: 11px;
    color: #FF671D;
    background: rgba(255,103,29,0.12);
    border-radius: 5px;
    padding: 6px 10px;
    margin-top: 6px;
    display: none;
  }

  /* Metrics */
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-bottom: 0.75rem;
  }
  .metric {
    background: #f4f6f9;
    border-radius: 8px;
    padding: 0.6rem 0.7rem;
  }
  .metric-label { font-size: 10px; color: #888; margin: 0 0 3px; text-transform: uppercase; letter-spacing: 0.04em; }
  .metric-value { font-size: 18px; font-weight: 700; color: #0C2340; margin: 0; }
  .metric-value.highlight { color: #0095A9; }
  .metric-sub { font-size: 10px; color: #aaa; margin: 1px 0 0; }

  /* Annual breakdown card */
  .annual-card {
    background: #f4f6f9;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }
  .annual-card-title {
    font-size: 11px;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.6rem;
  }
  .annual-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; font-size: 11px; }
  .annual-item p { margin: 0; }
  .annual-item .alabel { color: #888; margin-bottom: 2px; }
  .annual-item .aval { font-weight: 700; font-size: 13px; color: #0C2340; }
  .annual-item .anote { font-size: 10px; color: #bbb; margin-top: 1px; }

  /* Details / rate schedule */
  details summary {
    font-size: 12px;
    color: #0095A9;
    cursor: pointer;
    user-select: none;
    padding: 3px 0;
    list-style: none;
    font-weight: 500;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary::before { content: '▸  '; font-size: 10px; }
  details[open] summary::before { content: '▾  '; }
  .schedule-inner { margin-top: 8px; padding: 0.75rem; background: #f4f6f9; border-radius: 8px; }
  .schedule-table { width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 6px; }
  .schedule-table th { text-align: left; color: #888; font-weight: 500; padding: 3px 6px 6px; border-bottom: 1px solid #e0e0e0; }
  .schedule-table td { padding: 4px 6px; color: #1a1a1a; border-bottom: 0.5px solid #ebebeb; vertical-align: top; }
  .badge { display: inline-block; font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; }
  .badge-free    { background: #E1F5EE; color: #085041; }
  .badge-peak    { background: #FFF3CC; color: #7A5200; }
  .badge-offpeak { background: #E6F1FB; color: #0C447C; }
  .note { font-size: 10px; color: #aaa; margin: 6px 0 0; }

  /* Footer */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 0.6rem;
    border-top: 0.5px solid #e8e8e8;
    margin-top: 0.5rem;
  }
  .footer-note { font-size: 10px; color: #bbb; margin: 0; }
  button {
    font-size: 11px;
    padding: 4px 12px;
    border: 1px solid #0C2340;
    border-radius: 5px;
    background: transparent;
    color: #0C2340;
    cursor: pointer;
    font-family: inherit;
    font-weight: 500;
    transition: background 0.12s;
  }
  button:hover { background: #f0f4f8; }
  button:active { transform: scale(0.98); }

  @media (max-width: 420px) {
    .metrics { grid-template-columns: 1fr 1fr; }
    .annual-grid { grid-template-columns: 1fr 1fr; }
    .slider-meta { gap: 6px; }
  }
</style>
</head>
<body>
<div class="widget">
  <h1>How much could you save by shifting energy usage?</h1>
  <p class="subtitle">Adjust your usage across rate periods to see the impact on your bill</p>

  <div class="slider-card">
    <p class="card-title">Adjust usage distribution</p>

    <div class="slider-section">
      <div class="slider-header">
        <span class="slider-name free-label">Free</span>
        <div class="slider-meta">
          <span id="val-free">12.78%</span>
          <span id="kwh-free">1.37 kWh</span>
          <span class="cost" id="cost-free">$0.00</span>
        </div>
      </div>
      <input type="range" id="sl-free" min="0" max="100" value="12.78" step="0.01" aria-label="Free rate usage percentage">
    </div>

    <div class="slider-section">
      <div class="slider-header">
        <span class="slider-name peak-label">Peak</span>
        <div class="slider-meta">
          <span id="val-peak">33.22%</span>
          <span id="kwh-peak">3.55 kWh</span>
          <span class="cost" id="cost-peak">$2.26</span>
        </div>
      </div>
      <input type="range" id="sl-peak" min="0" max="100" value="33.22" step="0.01" aria-label="Peak rate usage percentage">
    </div>

    <div class="slider-section">
      <div class="slider-header">
        <span class="slider-name offpeak-label">Off-peak</span>
        <div class="slider-meta">
          <span id="val-offpeak">54.00%</span>
          <span id="kwh-offpeak">5.77 kWh</span>
          <span class="cost" id="cost-offpeak">$1.39</span>
        </div>
      </div>
      <input type="range" id="sl-offpeak" min="0" max="100" value="54" step="0.01" disabled aria-label="Off-peak usage (auto-calculated)">
    </div>

    <p class="hint">Off-peak adjusts automatically. Max daily usage: 10.6852 kWh.</p>
    <div class="warn" id="warn-box">&#9888; Total exceeds 100% — reduce free or peak usage.</div>
  </div>

  <div class="metrics">
    <div class="metric">
      <p class="metric-label">Energy cost</p>
      <p class="metric-value" id="m-energy">$3.65</p>
      <p class="metric-sub">per day</p>
    </div>
    <div class="metric">
      <p class="metric-label">Supply charge</p>
      <p class="metric-value">$1.76</p>
      <p class="metric-sub">per day, fixed</p>
    </div>
    <div class="metric">
      <p class="metric-label">Total daily</p>
      <p class="metric-value" id="m-daily">$5.41</p>
      <p class="metric-sub">energy + supply</p>
    </div>
    <div class="metric">
      <p class="metric-label">Annual cost</p>
      <p class="metric-value highlight" id="m-annual">$1,804</p>
      <p class="metric-sub">365 days</p>
    </div>
  </div>

  <div class="annual-card">
    <p class="annual-card-title">Annual breakdown</p>
    <div class="annual-grid">
      <div class="annual-item">
        <p class="alabel">Peak days (243)</p>
        <p class="aval" id="ann-peak-days">—</p>
        <p class="anote">Full peak rate</p>
      </div>
      <div class="annual-item">
        <p class="alabel">Off-peak days (122)</p>
        <p class="aval" id="ann-offpeak-days">—</p>
        <p class="anote">No peak rate</p>
      </div>
      <div class="annual-item">
        <p class="alabel">Supply charge</p>
        <p class="aval">$643.90</p>
        <p class="anote">365 × $1.764106</p>
      </div>
    </div>
  </div>

  <details>
    <summary>Rate schedule reference</summary>
    <div class="schedule-inner">
      <table class="schedule-table" aria-label="Rate schedule by time period">
        <thead>
          <tr><th>Rate</th><th>Hours</th><th>Cost/kWh</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="badge badge-free">Free</span></td>
            <td>11:00 am – 2:00 pm</td>
            <td style="color:#085041;">$0.000</td>
          </tr>
          <tr>
            <td><span class="badge badge-peak">Peak</span></td>
            <td>3:00 pm – 9:00 pm</td>
            <td style="color:#7A5200;">$0.637177</td>
          </tr>
          <tr>
            <td><span class="badge badge-offpeak">Off-peak</span></td>
            <td>9:00 pm – 11:00 am<br>2:00 pm – 3:00 pm</td>
            <td style="color:#0C447C;">$0.275597</td>
          </tr>
        </tbody>
      </table>
      <p class="note">Supply charge: $1.764106 per day (fixed, regardless of usage).</p>
      <p class="note">On the 122 non-peak days, any usage that would otherwise be charged at peak rate is recalculated at the off-peak rate instead.</p>
    </div>
  </details>

  <div class="footer">
    <p class="footer-note">Max daily usage: 10.6852 kWh &nbsp;·&nbsp; Peak rate applies 243 days/year</p>
    <button onclick="resetSliders()">&#8635; Reset</button>
  </div>
</div>

<script>
  // Actual kWh totals
  const BASE_FREE    = 1.3652;
  const BASE_PEAK    = 3.5497;
  const BASE_OFFPEAK = 5.7703;
  const TOTAL_KWH    = BASE_FREE + BASE_PEAK + BASE_OFFPEAK; // 10.6852

  const BASE_PCT_FREE    = BASE_FREE    / TOTAL_KWH * 100; // 12.7766
  const BASE_PCT_PEAK    = BASE_PEAK    / TOTAL_KWH * 100; // 33.2207
  const BASE_PCT_OFFPEAK = BASE_OFFPEAK / TOTAL_KWH * 100; // 54.0027

  const RATE_PEAK    = 0.637177;
  const RATE_OFFPEAK = 0.275597;
  const SUPPLY       = 1.764106;
  const PEAK_DAYS    = 243;
  const OFFPEAK_ONLY_DAYS = 122;

  const slFree    = document.getElementById('sl-free');
  const slPeak    = document.getElementById('sl-peak');
  const slOffpeak = document.getElementById('sl-offpeak');

  function fmt(n)    { return '$' + n.toFixed(2); }
  function fmtInt(n) { return '$' + Math.round(n).toLocaleString(); }
  function fmtPct(n) { return n.toFixed(2) + '%'; }

  function calc() {
    let pFree = parseFloat(slFree.value);
    let pPeak = parseFloat(slPeak.value);
    const sum = pFree + pPeak;
    let pOffpeak = Math.max(0, 100 - sum);
    const over = sum > 100;

    document.getElementById('warn-box').style.display = over ? 'block' : 'none';
    if (over) { pFree = Math.min(pFree, 100 - pPeak); pOffpeak = 0; }

    slOffpeak.value = pOffpeak;

    const kFree    = (pFree    / 100) * TOTAL_KWH;
    const kPeak    = (pPeak    / 100) * TOTAL_KWH;
    const kOffpeak = (pOffpeak / 100) * TOTAL_KWH;

    document.getElementById('val-free').textContent    = fmtPct(pFree);
    document.getElementById('val-peak').textContent    = fmtPct(pPeak);
    document.getElementById('val-offpeak').textContent = fmtPct(pOffpeak);

    document.getElementById('kwh-free').textContent    = kFree.toFixed(2)    + ' kWh';
    document.getElementById('kwh-peak').textContent    = kPeak.toFixed(2)    + ' kWh';
    document.getElementById('kwh-offpeak').textContent = kOffpeak.toFixed(2) + ' kWh';

    const cPeak    = kPeak    * RATE_PEAK;
    const cOffpeak = kOffpeak * RATE_OFFPEAK;

    document.getElementById('cost-free').textContent    = '$0.00';
    document.getElementById('cost-peak').textContent    = fmt(cPeak);
    document.getElementById('cost-offpeak').textContent = fmt(cOffpeak);

    const energyCost = cPeak + cOffpeak;
    const dailyCost  = energyCost + SUPPLY;

    document.getElementById('m-energy').textContent = fmt(energyCost);
    document.getElementById('m-daily').textContent  = fmt(dailyCost);

    const annPeakDays      = (energyCost + SUPPLY) * PEAK_DAYS;
    const offpeakDayEnergy = (kPeak * RATE_OFFPEAK) + (kOffpeak * RATE_OFFPEAK);
    const annOffpeakDays   = (offpeakDayEnergy + SUPPLY) * OFFPEAK_ONLY_DAYS;
    const annTotal         = annPeakDays + annOffpeakDays;

    document.getElementById('m-annual').textContent         = fmtInt(annTotal);
    document.getElementById('ann-peak-days').textContent    = fmtInt(annPeakDays);
    document.getElementById('ann-offpeak-days').textContent = fmtInt(annOffpeakDays);
  }

  function resetSliders() {
    slFree.value = BASE_PCT_FREE;
    slPeak.value = BASE_PCT_PEAK;
    calc();
  }

  slFree.addEventListener('input', calc);
  slPeak.addEventListener('input', calc);
  calc();
</script>
</body>
</html>
